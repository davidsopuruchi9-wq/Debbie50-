<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Random Fun Fact Generator</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            padding: 40px;
            max-width: 600px;
            width: 100%;
            text-align: center;
        }

        h1 {
            color: #333;
            margin-bottom: 30px;
            font-size: 2.5em;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .fact-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 10px;
            min-height: 150px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 30px 0;
            font-size: 1.2em;
            line-height: 1.6;
            font-weight: 500;
        }

        button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 1em;
            border-radius: 25px;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
        }

        button:active {
            transform: translateY(0);
        }

        .emoji {
            font-size: 3em;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎓 Fun Fact Generator</h1>
        <div class="emoji" id="emoji">📚</div>
        <div class="fact-box" id="factBox">
            Click the button to learn an amazing fact!
        </div>
        <button onclick="displayRandomFact()">Get Random Fact</button>
    </div>

    <script>
        const funFacts = [
            "🐙 Octopuses have three hearts - two pump blood to the gills, and one pumps it to the rest of the body!",
            "🍯 Honey never spoils. Archaeologists have found 3,000-year-old honey in Egyptian tombs that was still edible!",
            "🦙 Llamas can spit up to 10 feet and they do it when they feel threatened or annoyed.",
            "🌍 A day on Venus is longer than its year - Venus takes 243 Earth days to rotate on its axis, but only 225 days to orbit the Sun!",
            "🐧 Emperor penguins can dive deeper than 500 meters and hold their breath for over 20 minutes.",
            "🧠 Your brain generates enough electricity to power a small lightbulb.",
            "🍌 Bananas are berries, but strawberries aren't - berries develop from the ovary of a flowering plant!",
            "🦷 Sharks have been around longer than dinosaurs - they've existed for over 400 million years!",
            "✋ Your fingerprints are unique - even identical twins have different fingerprints!",
            "🌙 The Moon is slowly drifting away from Earth at about 1.5 inches per year.",
            "🐢 Some turtles can breathe through their butts - they can extract oxygen from water!",
            "☕ Coffee is the second most traded commodity in the world after oil.",
            "🦁 A lion's roar can be heard from 5 miles away!",
            "🌻 Sunflowers can track the movement of the Sun across the sky during the day.",
            "💎 Diamonds rain on Jupiter and Saturn!",
            "🐝 Honey bees can recognize human faces and remember them.",
            "🦑 Squid have rectangular pupils, unlike humans who have round ones.",
            "🌲 A single tree can provide a day's oxygen for four people.",
            "🧬 You share 50% of your DNA with bananas!",
            "👃 Humans can smell about 1 trillion different scents."
        ];

        function displayRandomFact() {
            const randomIndex = Math.floor(Math.random() * funFacts.length);
            const randomFact = funFacts[randomIndex];
            
            // Extract emoji from fact
            const emojiMatch = randomFact.match(/^[^\w\s]/);
            const emoji = emojiMatch ? emojiMatch[0] : '💡';
            
            document.getElementById('emoji').textContent = emoji;
            document.getElementById('factBox').textContent = randomFact;
        }

        // Display a random fact when page loads
        window.addEventListener('load', function() {
            displayRandomFact();
        });
    </script>
</body>
